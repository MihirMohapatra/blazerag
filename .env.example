# Blazerag Configuration

# Server
HOST=0.0.0.0
PORT=3000

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# Embedding Backend: "onnx" (local, fast) or "http" (remote, portable)
EMBEDDING_BACKEND=http
# For ONNX backend:
ONNX_MODEL_PATH=./models/all-MiniLM-L6-v2.onnx
# For HTTP backend:
EMBEDDING_API_URL=https://api-inference.huggingface.co/pipeline/feature-extraction/sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_API_KEY=hf_your_token_here
EMBEDDING_DIM=384

# LLM Provider (openai, anthropic, or custom)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=5
